{
  "permissions": {
    "allow": [
      "Bash(make lint:*)",
      "Bash(trunk check:*)",
      "Bash(bash:*)",
      "Bash(gh api:*)",
      "Bash(gh auth:*)",
      "Bash(jq:*)",
      "Bash(plugins/github-security-report/scripts/*:*)",
      "Bash(plugins/github-security-report/skills/*/scripts/*:*)"
